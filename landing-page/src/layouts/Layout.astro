---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Primo centralise toutes les informations cadastrales, urbanisme, risques et qualité de vie d'une parcelle en un clic.",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://primo-data.fr",
);
const siteUrl = Astro.site?.toString() || "https://primo-data.fr";
const fullOgImage = new URL(ogImage, siteUrl).toString();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="keywords"
      content="Primo, données cadastrales, PLU, urbanisme, parcelle, foncier, géorisques, immobilier France, cadastre, risques naturels"
    />
    <meta name="author" content="Primo" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Schema.org -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Primo",
        url: "https://primo-data.fr",
        description:
          "Plateforme centralisant toutes les informations cadastrales et foncières en France. Accédez aux données PLU, risques naturels, cadastre et qualité de vie en un clic.",
        applicationCategory: "BusinessApplication",
        operatingSystem: "Web, iOS, Android",
        offers: {
          "@type": "Offer",
          price: "0",
          priceCurrency: "EUR",
        },
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "Primo",
        url: "https://primo-data.fr",
        logo: "https://primo-data.fr/favicon.ico",
        description:
          "Primo centralise toutes les informations cadastrales, urbanisme, risques et qualité de vie d'une parcelle en un clic.",
        sameAs: [
          "https://www.linkedin.com/company/primo-data-app/",
          "https://www.instagram.com/primo.app/",
        ],
        contactPoint: {
          "@type": "ContactPoint",
          email: "contact@primo-data.fr",
          contactType: "customer service",
          availableLanguage: "French",
        },
      })}
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
